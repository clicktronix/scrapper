# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# OpenAI
OPENAI_API_KEY=sk-...

# Instagram аккаунты (через запятую)
INSTAGRAM_ACCOUNTS=account1,account2

# Креды аккаунтов
IG_ACCOUNT1_USERNAME=...
IG_ACCOUNT1_PASSWORD=...
IG_ACCOUNT2_USERNAME=...
IG_ACCOUNT2_PASSWORD=...

# Прокси (residential, sticky sessions)
PROXY_ACCOUNT1=http://user:pass@gate.decodo.com:7001
PROXY_ACCOUNT2=http://user:pass@gate.decodo.com:7002

# Rate limiting
SCRAPE_DELAY_MIN=1.5
SCRAPE_DELAY_MAX=4.0
REQUESTS_PER_HOUR=30
COOLDOWN_MINUTES=45

# Контент
POSTS_TO_FETCH=25
HIGHLIGHTS_TO_FETCH=3
COMMENTS_TO_FETCH=10
POSTS_WITH_COMMENTS=3
THUMBNAILS_TO_PERSIST=7

# Pre-filter
PRE_FILTER_MIN_LIKES=30
PRE_FILTER_MAX_INACTIVE_DAYS=180
PRE_FILTER_POSTS_TO_CHECK=5

# AI Batch
BATCH_MIN_SIZE=10
BATCH_MODEL=gpt-5-mini
EMBEDDING_MODEL=text-embedding-3-small

# Фильтрация свежести
RESCRAPE_DAYS=60

# Воркер
WORKER_POLL_INTERVAL=30
WORKER_MAX_CONCURRENT=2
LOG_LEVEL=INFO

# API
SCRAPER_API_KEY=sk-scraper-change-me
SCRAPER_PORT=8001
API_DOCS_ENABLED=false
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_TRUST_FORWARDED_FOR=false
# TRUSTED_PROXY_IPS=203.0.113.10,203.0.113.11

# HikerAPI (альтернативный бэкенд, fallback если аккаунты заблокированы)
# HIKERAPI_TOKEN=...
# SCRAPER_BACKEND=hikerapi  # "instagrapi" (default) | "hikerapi"
